# ─── LearnArc FastAPI — Environment Variables Template ────────────────────────
# Copy this file to .env and fill in your actual values.
# The .env file is gitignored and must NEVER be committed to version control.
#
# Usage:
#   cp .env.example .env
#   # then edit .env with your real values

# ── Database ──────────────────────────────────────────────────────────────────
# Connection details for your MySQL database.
DB_HOST=localhost
DB_PORT=3306
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_NAME=course_platform

# Set to true to print all SQL queries to the console (useful for debugging).
# NEVER set to true in production — extremely verbose.
DB_ECHO=false

# ── JWT Authentication ────────────────────────────────────────────────────────
# Generate a strong random secret:
#   python -c "import secrets; print(secrets.token_hex(32))"
# The app will REFUSE to start if this is not set or is left as the placeholder.
SECRET_KEY=REPLACE_WITH_A_REAL_RANDOM_SECRET

# JWT signing algorithm — HS256 is standard.
ALGORITHM=HS256

# How long access tokens remain valid (in minutes).
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of frontend origins allowed to make cross-origin requests.
# Development: http://localhost:3000,http://localhost:5173
# Production:  https://yourapp.com,https://www.yourapp.com
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ── Server ────────────────────────────────────────────────────────────────────
# Number of gunicorn worker processes (Docker/production only).
# Recommended: 2 * CPU cores + 1. Start with 2 for small instances.
WEB_CONCURRENCY=2
