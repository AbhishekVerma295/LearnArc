# Normalize line endings: store LF in git, checkout as-is on Windows
* text=auto
*.py text eol=lf
*.md text eol=lf
*.ini text eol=lf
*.sql text eol=lf
*.html text eol=lf
*.css text eol=lf
*.txt text eol=lf
*.mako text eol=lf
# Shell scripts and YAML MUST use LF — CRLF breaks bash in Linux containers
*.sh text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
